# Public beta runtime
PROJECT_NAME=Battery-RAG Agent
APP_ENV=production
PUBLIC_HTTP_PORT=80

# Frontend public runtime
# Leave blank to use same-origin /api behind Nginx, or set the full public origin if needed.
NEXT_PUBLIC_API_BASE_URL=

# Backend network + auth
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=https://battery-rag.example.com
JWT_SECRET=replace-with-a-strong-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=60
COOKIE_NAME=access_token
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=battery-rag.example.com

# Storage
STORAGE_ROOT=/app/storage
MAX_UPLOAD_SIZE_BYTES=10485760
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.txt,.md,.csv
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,text/plain,text/markdown,text/csv,application/csv
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
CSV_PREVIEW_CHAR_LIMIT=5000
EXPERIMENT_PREVIEW_ROWS=20
EXPERIMENT_CHART_POINT_LIMIT=60

# PostgreSQL
POSTGRES_DB=battery_rag
POSTGRES_USER=battery_rag
POSTGRES_PASSWORD=replace-with-a-strong-db-password

# Redis
# Redis remains single-node in public beta and should stay on a persistent volume.

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=battery_rag_chunks

# Backend-only LLM / embedding settings
LLM_PROVIDER=mock
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_CHAT_MODEL=mock-chat
LLM_EMBEDDING_MODEL=mock-embedding

# RAG / chat
RAG_TOP_K=4
RAG_MIN_SIMILARITY=0.15
CHAT_HISTORY_LIMIT=6

# Agent / skills
AGENT_ENABLE_LLM_ROUTING=false
AGENT_MIN_PROMPT_CHARACTERS=18
AGENT_MAX_CLAIMS=6
AGENT_MAX_COMPARISON_DOCUMENTS=3

# External references
EXTERNAL_TOOL_USER_AGENT=Battery-RAG-Agent/0.1 (+https://battery-rag.example.com/manual-verification-required)
EXTERNAL_SEARCH_TIMEOUT_SECONDS=15
CROSSREF_MAILTO=

# Public beta reminders:
# 1. Keep this file out of Git after you copy it to .env.production.
# 2. Provider keys and JWT secrets must stay backend-only.
# 3. HTTPS is strongly recommended before exposing login flows publicly.
