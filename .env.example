# Project
PROJECT_NAME=Battery-RAG Agent
APP_ENV=development

# Frontend
NEXT_PUBLIC_APP_NAME=Battery-RAG Agent
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000
JWT_SECRET=change-me-for-local-development
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=60
COOKIE_NAME=access_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
DATABASE_URL=
STORAGE_ROOT=storage
MAX_UPLOAD_SIZE_BYTES=10485760
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.txt,.md,.csv
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,text/plain,text/markdown,text/csv,application/csv
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
CSV_PREVIEW_CHAR_LIMIT=5000

# PostgreSQL
POSTGRES_DB=battery_rag
POSTGRES_USER=battery_rag
POSTGRES_PASSWORD=battery_rag_password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Qdrant
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=battery_rag_chunks

# LLM / Embedding Gateway
LLM_PROVIDER=mock
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_CHAT_MODEL=mock-chat
LLM_EMBEDDING_MODEL=mock-embedding

# RAG / Chat
RAG_TOP_K=4
RAG_MIN_SIMILARITY=0.15
CHAT_HISTORY_LIMIT=6

# Agent / Skills
AGENT_ENABLE_LLM_ROUTING=false
AGENT_MIN_PROMPT_CHARACTERS=18
AGENT_MAX_CLAIMS=6
AGENT_MAX_COMPARISON_DOCUMENTS=3
